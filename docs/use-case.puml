@startuml
left to right direction
actor "Пользователь" as User
actor "Система" as System

rectangle "SubTrack" {
  User --> (Регистрация)
  User --> (Авторизация)
  User --> (Управление подписками)
  User --> (Просмотр дашборда)
  User --> (Просмотр аналитики)
  User --> (Экспорт данных)
  User --> (Отметить «пересмотреть»)

  (Управление подписками) --> (Создать подписку)
  (Управление подписками) --> (Редактировать подписку)
  (Управление подписками) --> (Удалить подписку)

  System --> (Отправка уведомлений)
  System --> (Обновление курса валют)
}

note right of (Экспорт данных)
  CSV / PDF
end note
@enduml
