@startuml
start
:Регистрация / Вход;
if (Авторизован?) then (да)
else (нет)
  :Ввод email и пароля;
  :JWT-токен сохранён в localStorage;
endif

:Главный экран — Дашборд;
:Просмотр итоговой суммы в месяц/год;
:Просмотр ближайших списаний на 7 дней;

if (Добавить подписку?) then (да)
  :Заполнение формы:
  название, сумма, валюта,
  периодичность, дата, категория;
  :Подписка сохранена в БД;
else (нет)
endif

if (Редактировать/удалить?) then (да)
  :Изменение параметров подписки;
  :или удаление;
else (нет)
endif

if (Отметить "пересмотреть"?) then (да)
  :Флаг review_flag = true;
else (нет)
endif

:Переход в Аналитику;
:Просмотр круговой диаграммы
расходов по категориям;

if (Экспорт?) then (да)
  :Скачивание CSV / PDF;
else (нет)
endif

:Выход из системы;
stop
@enduml
